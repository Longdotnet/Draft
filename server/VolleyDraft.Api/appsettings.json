{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "Postgres"
  },
  "Public": {
    "BaseUrl": ""
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=volley_draft;Username=postgres;Password=123123"
  },
  "Jwt": {
    "Issuer": "VolleyDraft",
    "Audience": "VolleyDraftClient",
    "Key": "dev-only-volley-draft-mvp-jwt-signing-key-change-later"
  },
  "ZaloBot": {
    "ConversationTtlMinutes": 15,
    "ExactCommandCooldownSeconds": 2,
    "AiCooldownSeconds": 10,
    "AiPerUserPerMinute": 4,
    "AiPerGroupPerMinute": 20,
    "AiStyleEnabled": true,
    "ClassifierConfidenceThreshold": 0.72,
    "LearnedRuleSimilarityThreshold": 0.82
  },
  "Scheduler": {
    "Key": "",
    "PollRefreshMinutes": 20,
    "RetryMinutes": 10,
    "UrgentWindowHours": 1,
    "UrgentDelayMinutes": 0
  }
}
